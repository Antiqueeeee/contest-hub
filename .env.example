# ── Contest Hub 配置文件 ──────────────────────────────────────────
# 复制此文件为 .env 并填写实际值:
#   cp .env.example .env
#
# 标记为 [必填] 的字段必须在启动前填写。
# ──────────────────────────────────────────────────────────────────

# [必填] 数据库密码（可含特殊字符，系统会自动编码）
DB_PASSWORD=

# [必填] JWT 签名密钥。生成方式:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# [必填] PII 加密密钥（用于加密身份证号、手机号）。生成方式:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=


# ── 可选配置 ─────────────────────────────────────────────────────

# JWT 过期时间（分钟），默认 120
# JWT_EXPIRE_MINUTES=120

# CORS 允许的前端来源，逗号分隔
# ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

# 前端端口（默认 80）
# PORT=80


# ── 生产环境 HTTPS（客户自行配置外层 nginx） ───────────────────
#
# 如需启用 HTTPS，请在服务器外层 nginx 中配置 SSL 证书，并将请求
# 反向代理到本项目的 HTTP 端口。示例配置:
#
#   server {
#       listen 443 ssl;
#       server_name your-domain.com;
#
#       ssl_certificate     /path/to/fullchain.pem;
#       ssl_certificate_key /path/to/privkey.pem;
#
#       location / {
#           proxy_pass http://127.0.0.1:80;
#           proxy_set_header Host $host;
#           proxy_set_header X-Real-IP $remote_addr;
#           proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#           proxy_set_header X-Forwarded-Proto https;   # ← 关键: 必须设这个头
#       }
#   }
#
#   server {
#       listen 80;
#       server_name your-domain.com;
#       return 301 https://$server_name$request_uri;
#   }
#
# 核心要点: 外层 nginx 必须设置 X-Forwarded-Proto: https，
# 项目内的 nginx 会自动透传，后端据此正确处理 CORS 和重定向。
